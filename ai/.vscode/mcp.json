{
  "servers": {
    "io.github.upstash/context7": {
      "type": "stdio",
      "command": "npx",
      "args": [
        "-y",
        "@upstash/context7-mcp"
      ],
      "env": {
        "CONTEXT7_API_KEY": "${input:context7-api-key}"
      }
    },
    "com.microsoft/azure": {
      "type": "stdio",
      "command": "npx",
      "args": [
        "-y",
        "@azure/mcp",
        "server",
        "start"
      ]
    },
    "com.atlassian/atlassian-mcp-server": {
      "type": "http",
      "url": "https://mcp.atlassian.com/v1/mcp",
      "headers": {}
    },
    "github": {
      "type": "http",
      "url": "https://api.githubcopilot.com/mcp/",
      "headers": {}
    },
    "microsoft-docs": {
      "type": "http",
      "url": "https://learn.microsoft.com/api/mcp/",
      "headers": {}
    },
    "mermaid": {
      "type": "http",
      "url": "https://mcp.mermaidchart.com/mcp/",
      "headers": {}
    },
    "agentic-workflows": {
      "type": "stdio",
      "command": "gh",
      "args": [
        "aw",
        "mcp-server"
      ]
    },
    "pendo": {
      "type": "http",
      "url": "https://app.pendo.io/mcp/v0/shttp",
      "headers": {}
    },
    "atlassian": {
      "type": "http",
      "url": "https://mcp.atlassian.com/v1/mcp",
      "headers": {}
    },
    "figma": {
      "type": "http",
      "url": "https://mcp.figma.com/mcp",
      "headers": {}
    },
    "t": {
      "type": "stdio",
      "command": "node",
      "args": [
        "C:\\Users\\ddriscoll\\dotfiles\\ai\\apm_modules\\Yeachan-Heo\\oh-my-claudecode/bridge/mcp-server.cjs"
      ]
    }
  },
  "inputs": [
    {
      "type": "promptString",
      "id": "context7-api-key",
      "description": "API key for authentication",
      "password": true
    }
  ]
}