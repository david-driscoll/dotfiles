{
  "mcpServers": {
    "context7": {
      "type": "stdio",
      "command": "npx",
      "args": [
        "-y",
        "@upstash/context7-mcp"
      ],
      "env": {
        "CONTEXT7_API_KEY": "ctx7sk-9994b87c-0256-4fc1-9271-04bad67cfb5b"
      }
    },
    "github-mcp-server": {
      "type": "http",
      "url": "https://api.githubcopilot.com/mcp/",
      "id": "36469f602f054de89d21098ba0586dc3",
      "headers": {}
    },
    "mcp": {
      "type": "http",
      "url": "https://learn.microsoft.com/api/mcp"
    },
    "mermaid": {
      "type": "http",
      "url": "https://mcp.mermaidchart.com/mcp/"
    },
    "nuget": {
      "type": "stdio",
      "command": "dnx",
      "args": [
        "NuGet.Mcp.Server",
        "--source",
        "https://api.nuget.org/v3/index.json",
        "--yes"
      ]
    },
    "agentic-workflows": {
      "type": "stdio",
      "command": "gh",
      "args": [
        "aw",
        "mcp-server"
      ]
    },
    "duckduckgo": {
      "type": "stdio",
      "command": "npx",
      "args": [
        "-y",
        "duckduckgo-mcp-server"
      ]
    },
    "github": {
      "type": "stdio",
      "command": "gh",
      "env": {
        "GITHUB_DYNAMIC_TOOLSETS": "1"
      },
      "args": [
        "mcp"
      ]
    },
    "binlog": {
      "type": "stdio",
      "command": "dotnet",
      "args": [
        "dnx",
        "Microsoft.AITools.BinlogMcp",
        "--yes",
        "--prerelease",
        "--add-source",
        "https://pkgs.dev.azure.com/dnceng/public/_packaging/dotnet-tools/nuget/v3/index.json"
      ]
    }
  }
}
