{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": ["config:recommended"],
  "enabledManagers": ["mise"],
  "automerge": true,
  "mise": {
    "fileMatch": [
      "\\.mise\\.toml$",
      "mise\\.toml$",
      "\\.mise/config\\.toml$",
      "mise/config\\.toml$"
    ]
  }
}
