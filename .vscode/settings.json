{
    "files.associations": {
        "*.yaml": "home-assistant"
    },
    "editor.fontFamily": "JetbrainsMono Nerd Font Propo",
    "editor.formatOnSave": false,
    "snyk.advanced.autoSelectOrganization": true,
    "workbench.colorCustomizations": {
        "activityBar.activeBackground": "#11d4ed",
        "activityBar.background": "#11d4ed",
        "activityBar.foreground": "#15202b",
        "activityBar.inactiveForeground": "#15202b99",
        "activityBarBadge.background": "#ee11d5",
        "activityBarBadge.foreground": "#e7e7e7",
        "editorGroup.border": "#11d4ed",
        "panel.border": "#11d4ed",
        "sash.hoverBorder": "#11d4ed",
        "sideBar.border": "#11d4ed",
        "statusBar.background": "#11d4ed",
        "statusBar.debuggingBackground": "#ed2a11",
        "statusBar.debuggingForeground": "#e7e7e7",
        "statusBar.foreground": "#15202b",
        "statusBarItem.hoverBackground": "#0ea9bd",
        "statusBarItem.remoteBackground": "#11d4ed",
        "statusBarItem.remoteForeground": "#15202b",
        "tab.activeBorder": "#11d4ed"
    },
    "peacock.color": "#11d4ed",
}