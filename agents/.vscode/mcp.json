{
	"servers": {
		"mise": {
			"type": "stdio",
			"command": "mise",
			"args": [
				"mcp"
			],
			"env": {
				"MISE_EXPERIMENTAL": "1"
			}
		},
		"microsoft/playwright-mcp": {
			"type": "stdio",
			"command": "npx",
			"args": [
				"@playwright/mcp@latest"
			],
			"gallery": "https://api.mcp.github.com",
			"version": "0.0.1-seed"
		}
	},
	"inputs": []
}